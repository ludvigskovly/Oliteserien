{
  "version": 2,
  "builds": [
    { "src": "api/sheet.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" },
    { "src": "crest.svg", "use": "@vercel/static" },
    { "src": "jogge.jpg", "use": "@vercel/static" },
    { "src": "stegane.jpg", "use": "@vercel/static" },
    { "src": "augen.jpg", "use": "@vercel/static" },
    { "src": "espen.jpg", "use": "@vercel/static" },
    { "src": "elling.jpg", "use": "@vercel/static" },
    { "src": "ludde.jpg", "use": "@vercel/static" },
    { "src": "tage.jpg", "use": "@vercel/static" },
    { "src": "alf.jpg", "use": "@vercel/static" },
    { "src": "knut.jpg", "use": "@vercel/static" },
    { "src": "aleks.jpg", "use": "@vercel/static" },
    { "src": "ivar.jpg", "use": "@vercel/static" },
    { "src": "siggen.jpg", "use": "@vercel/static" },
    { "src": "kal.jpg", "use": "@vercel/static" },
    { "src": "hegre.jpg", "use": "@vercel/static" },
    { "src": "sindre.jpg", "use": "@vercel/static" },
    { "src": "nikolai.jpg", "use": "@vercel/static" },
    { "src": "madslien.jpg", "use": "@vercel/static" },
    { "src": "kiffen.jpg", "use": "@vercel/static" },
    { "src": "jens.jpg", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/sheet", "dest": "/api/sheet.js" },
    { "src": "/(app\\.js|styles\\.css|crest\\.svg|jogge\\.jpg|stegane\\.jpg|augen\\.jpg|espen\\.jpg|elling\\.jpg|ludde\\.jpg|tage\\.jpg|alf\\.jpg|knut\\.jpg|aleks\\.jpg|ivar\\.jpg|siggen\\.jpg|kal\\.jpg|hegre\\.jpg|sindre\\.jpg|nikolai\\.jpg|madslien\\.jpg|kiffen\\.jpg|jens\\.jpg)", "dest": "/$1" },
    { "src": "/.*", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/sheet",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=30, stale-while-revalidate=120" }
      ]
    }
  ]
}
