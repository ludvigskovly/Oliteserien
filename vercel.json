{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*\\.(?:js|css|svg|jpg|jpeg|png|ico))", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ],
  "headers": [
    {
      "source": "/api/sheet",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=30, stale-while-revalidate=120" }
      ]
    }
  ]
}
